# Telegram Bot Token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Admin authentication token (any secure string)
ADMIN_TOKEN=your_secure_admin_token_here

# Admin Telegram numeric IDs (comma-separated for multiple admins)
ADMIN_TELEGRAM_IDS=2060988783,822479618

# PostgreSQL connection string for the restricted-role user
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server port (default 3000)
PORT=3000

# Environment: development or production
NODE_ENV=development

# Fixed referral link shown to verified users
REFERRAL_LINK=https://trackmyaff.com/?serial=61347612&creative_id=7376&anid=822479618

# Public HTTPS URL of the server (required in production for webhook)
# For Railway: https://your-app.railway.app
# For Vercel:  https://your-app.vercel.app
WEBHOOK_URL=https://your-app.railway.app

# Public URL of the app (used for CORS). Same as WEBHOOK_URL in most cases.
APP_URL=https://your-app.railway.app

# 64-char hex string used as secret path for bot webhook
WEBHOOK_SECRET_PATH=aabbccdd...64hexchars...

# Mini App URL for the bot's inline keyboard button
MINI_APP_URL=https://t.me/your_bot/your_app
